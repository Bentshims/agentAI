        {
            "parameters": {
                "jsCode": "const response = $input.first().json || {};\nconst content = response?.choices?.[0]?.message?.content || \u0027\u0027;\nconst prospect = $(\u0027Split Boucle Relances\u0027).first().json || {};\n\nlet emailData;\nlet generation_source = \u0027deepseek\u0027;\ntry {\n  const clean = String(content).replace(/```json|```/g, \u0027\u0027).trim();\n  emailData = JSON.parse(clean);\n} catch (e) {\n  emailData = {};\n  generation_source = \u0027fallback\u0027;\n}\n\nconst normalize = (value, fallback = \u0027\u0027) =\u003e typeof value === \u0027string\u0027 ? value.trim() || fallback : fallback;\nconst prochainStatut = prospect.statut === \u0027email_envoye\u0027 ? \u0027relance_1\u0027 : \u0027relance_2\u0027;\nconst typeEmail = prospect.statut === \u0027email_envoye\u0027 ? \u0027relance_1\u0027 : \u0027relance_2_breakup\u0027;\n\nlet objet = normalize(emailData.objet, prospect.statut === \u0027email_envoye\u0027 ? \u0027Petit suivi\u0027 : \u0027Je clos ce sujet\u0027);\nlet corps = normalize(emailData.corps, \u0027\u0027);\n\nif (!corps || corps.length \u003c 40) {\n  generation_source = \u0027fallback\u0027;\n  corps = prospect.statut === \u0027email_envoye\u0027\n    ? `Bonjour ${prospect.nom || \u0027\u0027},\n\nJe me permets de revenir vers vous concernant mon precedent message. Si le sujet est pertinent pour vous, je peux vous faire un retour tres synthetique ou m\u0027adapter a votre contexte.\n\nDites-moi simplement si cela vaut la peine d\u0027en parler.\n\nBien cordialement`\n    : `Bonjour ${prospect.nom || \u0027\u0027},\n\nJe vous laisse ce dernier message et je ne relancerai pas davantage. Si le sujet devient d\u0027actualite plus tard, je serai ravi d\u0027en reparler avec vous.\n\nBien cordialement`;\n}\n\nreturn [{\n  json: {\n    prospect_id: prospect.id,\n    prospect_email: prospect.email,\n    prospect_nom: prospect.nom,\n    chat_id: prospect.chat_id || \u0027\u0027,\n    email_objet: objet,\n    email_corps: corps,\n    prochain_statut: prochainStatut,\n    type_email: typeEmail,\n    generation_source\n  }\n}];"
            },
