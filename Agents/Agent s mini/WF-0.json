        {
            "parameters": {
                "jsCode": "const data = $input.first().json;\nconst message = data.message || {};\nconst texte = message.text || \u0027\u0027;\nconst chat_id = String(message.chat?.id || \u0027\u0027);\nconst from = message.from || {};\n\n// Ignorer les messages vides ou trop courts.\nif (!texte || texte.length < 2) {\n  return [];\n}\n\nreturn [{\n  json: {\n    texte: texte,\n    chat_id: chat_id,\n    prenom: from.first_name || \u0027\u0027,\n    message_id: message.message_id || null\n  }\n}];"
            },
            "id": "16c0ab3a-d155-450b-a310-a689d4157384",
            "name": "Extraire Message Telegram",
            "type": "n8n-nodes-base.code",
