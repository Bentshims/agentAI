        {
            "parameters": {
                "jsCode": "const response = $input.first().json;\nconst content = (response.choices[0].message.content || \u0027\u0027).trim();\nconst messageData = $(\u0027Extraire Message Telegram\u0027).first().json;\n\n// Parser l\u0027index. DeepSeek doit retourner 0, 1 ou 2.\nlet index = parseInt(content, 10);\nif (isNaN(index) || index < 0 || index > 2) {\n  index = 2; // Fallback sur aide.\n}\n\nreturn [{\n  json: {\n    intention_index: index,\n    texte: messageData.texte,\n    chat_id: messageData.chat_id,\n    prenom: messageData.prenom\n  }\n}];"
            },
