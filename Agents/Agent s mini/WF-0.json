            "parameters": {
                "method": "POST",
                "url": "https://api.deepseek.com/chat/completions",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"model\": \"deepseek-chat\",\n  \"temperature\": 0,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un routeur d\u0027intention pour un agent commercial. Tu dois classer un message entrant dans UNE seule categorie. Categories: 0 = demande de recherche de prospects, prospection, scraping, trouver des contacts, chercher des entreprises ou freelances; 1 = demande de planification d\u0027appel, rendez-vous, RDV, meeting, call, rappel, calendrier, horaire; 2 = tout le reste, y compris aide, salutation, ambiguite, question generale. Regles obligatoires: reponds uniquement par un seul caractere parmi 0, 1 ou 2. Aucun mot, aucune ponctuation, aucune explication. En cas de doute, retourne 2.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $json.texte }}\"\n    }\n  ]\n}",
                "options": {}
            },
