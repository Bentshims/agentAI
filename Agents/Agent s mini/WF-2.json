        {
            "parameters": {
                "chatId": "=7993226930",
                "text": "={{ \n  const p = $(\u0027Extraire Scoring DeepSeek\u0027).first().json;\n  const niveau = p.score_pertinence >= 8 ? \u0027chaud\u0027 : p.score_pertinence >= 6 ? \u0027solide\u0027 : \u0027faible\u0027;\n  let msg = `*Prospect score ${p.score_pertinence}/10*\\n`;\n  msg += `Niveau : \\`${niveau}\\` | Type : \\`${p.type}\\` | Interet : \\`${p.niveau_interet}\\`\\n\\n`;\n  msg += `*Nom :* ${p.nom || \u0027Inconnu\u0027}\\n`;\n  if (p.email) msg += `*Email :* ${p.email}${p.email_valide ? \u0027 (valide)\u0027 : \u0027 (a verifier)\u0027}\\n`;\n  if (p.telephone) msg += `*Tel :* ${p.telephone}\\n`;\n  if (p.linkedin_url) msg += `*LinkedIn :* ${p.linkedin_url}\\n`;\n  if (p.site_web) msg += `*Site :* ${p.site_web}\\n`;\n  if (p.localisation) msg += `*Localisation :* ${p.localisation}\\n`;\n  msg += `\\n*Resume :*\\n${p.resume_profil || \u0027Non disponible\u0027}\\n`;\n  if (p.points_forts && p.points_forts.length > 0) {\n    msg += `\\n*Points forts :* ${p.points_forts.join(\u0027 | \u0027)}\\n`;\n  }\n  msg += `\\n_${p.justification_score || \u0027\u0027}_`;\n  return msg;\n}}",
                "additionalFields": {
                    "disable_notification": false,
                    "parse_mode": "Markdown"
                }
            },
