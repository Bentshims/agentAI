        {
            "parameters": {
                "jsCode": "const response = $input.first().json;\nconst content = response.choices[0].message.content;\n\nlet scoring;\ntry {\n  const clean = content.replace(/```json|```/g, '').trim();\n  scoring = JSON.parse(clean);\n} catch(e) {\n  // Fallback si JSON invalide\n  scoring = {\n    score: 3,\n    justification_score: 'Erreur analyse DeepSeek',\n    resume_profil: 'Analyse indisponible',\n    points_forts: [],\n    points_faibles: ['Analyse échouée'],\n    niveau_interet: 'froid',\n    email_valide: false,\n    a_contacter: false,\n    nom_enrichi: '',\n    description_enrichie: ''\n  };\n}\n\n// Récupérer les données du prospect depuis la boucle\nconst prospect = $('Split Boucle Prospects').first().json;\n\nreturn [{\n  json: {\n    // Données originales\n    prospect_id: prospect.id,\n    chat_id: prospect.chat_id,\n    session_id: prospect.session_id,\n    type: prospect.type,\n    nom: scoring.nom_enrichi || prospect.nom,\n    email: prospect.email,\n    telephone: prospect.telephone,\n    site_web: prospect.site_web,\n    linkedin_url: prospect.linkedin_url,\n    localisation: prospect.localisation,\n    secteur: prospect.secteur,\n    // Données enrichies par DeepSeek\n    score_pertinence: scoring.score || 0,\n    justification_score: scoring.justification_score || '',\n    resume_profil: scoring.resume_profil || '',\n    points_forts: scoring.points_forts || [],\n    points_faibles: scoring.points_faibles || [],\n    niveau_interet: scoring.niveau_interet || 'froid',\n    email_valide: scoring.email_valide || false,\n    a_contacter: scoring.a_contacter || false,\n    description_enrichie: scoring.description_enrichie || prospect.description || ''\n  }\n}];"
            },
            "id": "7277427d-2c3c-4e83-88ea-4c7e47da4a79",
            "name": "Extraire Scoring DeepSeek",
            "type": "n8n-nodes-base.code",
