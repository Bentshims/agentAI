        {
            "parameters": {
                "method": "POST",
                "url": "https://api.deepseek.com/chat/completions",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendBody": true,
                "specifyBody": "json",
                "options": {},
                "jsonBody": "={\n  \"model\": \"deepseek-chat\",\n  \"temperature\": 0.2,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un analyste senior de qualification B2B/B2C. Tu recois une fiche prospect brute et tu dois produire STRICTEMENT un JSON valide, sans markdown ni commentaire, avec les cles exactes: score, justification_score, resume_profil, points_forts, points_faibles, niveau_interet, email_valide, a_contacter, nom_enrichi, description_enrichie. Regles: score est un entier de 0 a 10; points_forts et points_faibles sont des tableaux de 0 a 4 chaines courtes; niveau_interet doit etre exactement \u0027chaud\u0027, \u0027tiede\u0027 ou \u0027froid\u0027; email_valide et a_contacter sont booleens. Base ton analyse sur l\u0027adequation au besoin, la qualite du contact, la clarte de l\u0027offre, la localisation et les criteres de scoring fournis. Si les donnees sont faibles, degrade le score. a_contacter doit etre true seulement si le prospect semble pertinent et exploitable commercialement. nom_enrichi doit rester tres proche du nom source, sans invention. description_enrichie doit etre un resume commercial propre, factuel et concis, inferieur a 600 caracteres.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ JSON.stringify({ prospect: $(\u0027Split Boucle Prospects\u0027).first().json, criteres_scoring: $(\u0027Split Boucle Prospects\u0027).first().json.criteres_scoring || \u0027\u0027 }) }}\"\n    }\n  ]\n}"
            },
            "id": "25c0f90e-e1df-4b2a-b39d-47239366d493",
            "name": "DeepSeek Analyser et Scorer Prospect",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                224,
                9456
            ],
            "credentials": {
                "httpHeaderAuth": {
                    "id": "Fi7piKShxfsxAA0V",
                    "name": "Header Auth agent_s"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "const response = $input.first().json || {};\nconst content = response?.choices?.[0]?.message?.content || \u0027\u0027;\nconst prospect = $(\u0027Split Boucle Prospects\u0027).first().json || {};\n\nlet scoring;\nlet analyse_source = \u0027deepseek\u0027;\ntry {\n  const clean = String(content).replace(/```json|```/g, \u0027\u0027).trim();\n  scoring = JSON.parse(clean);\n} catch (e) {\n  scoring = {};\n  analyse_source = \u0027fallback\u0027;\n}\n\nconst toInt = (value, fallback) =\u003e {\n  const parsed = Number.parseInt(value, 10);\n  return Number.isFinite(parsed) ? parsed : fallback;\n};\n\nconst clamp = (value, min, max) =\u003e Math.max(min, Math.min(max, value));\nconst normalizeText = (value, fallback = \u0027\u0027) =\u003e {\n  if (typeof value !== \u0027string\u0027) return fallback;\n  return value.trim() || fallback;\n};\nconst normalizeArray = (value) =\u003e Array.isArray(value) ? value.filter(v =\u003e typeof v === \u0027string\u0027 \u0026\u0026 v.trim()).slice(0, 4) : [];\nconst normalizeInterest = (value) =\u003e [\u0027chaud\u0027, \u0027tiede\u0027, \u0027froid\u0027].includes(value) ? value : \u0027froid\u0027;\n\nconst score = clamp(toInt(scoring.score, 3), 0, 10);\nconst justification = normalizeText(scoring.justification_score, \u0027Analyse partielle indisponible.\u0027);\nconst resume = normalizeText(scoring.resume_profil, \u0027Profil non analyse en detail.\u0027);\nconst descriptionEnrichie = normalizeText(scoring.description_enrichie, prospect.description || \u0027\u0027).slice(0, 600);\nconst nomEnrichi = normalizeText(scoring.nom_enrichi, prospect.nom || \u0027Inconnu\u0027);\n\nreturn [{\n  json: {\n    prospect_id: prospect.id,\n    chat_id: prospect.chat_id,\n    session_id: prospect.session_id,\n    type: prospect.type,\n    nom: nomEnrichi,\n    email: prospect.email,\n    telephone: prospect.telephone,\n    site_web: prospect.site_web,\n    linkedin_url: prospect.linkedin_url,\n    localisation: prospect.localisation,\n    secteur: prospect.secteur,\n    score_pertinence: score,\n    justification_score: justification,\n    resume_profil: resume,\n    points_forts: normalizeArray(scoring.points_forts),\n    points_faibles: normalizeArray(scoring.points_faibles),\n    niveau_interet: normalizeInterest(scoring.niveau_interet),\n    email_valide: Boolean(scoring.email_valide),\n    a_contacter: Boolean(scoring.a_contacter) \u0026\u0026 score \u003e= 6,\n    analyse_source,\n    description_enrichie: descriptionEnrichie || (prospect.description || \u0027\u0027)\n  }\n}];"
            },
            "id": "7277427d-2c3c-4e83-88ea-4c7e47da4a79",
