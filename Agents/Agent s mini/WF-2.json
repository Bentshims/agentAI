        {
            "parameters": {
                "chatId": "=7993226930",
                "text": "={{ \n  const p = $('Extraire Scoring DeepSeek').first().json;\n  const scoreEmoji = p.score_pertinence >= 8 ? '🔥' : p.score_pertinence >= 6 ? '✅' : '🟡';\n  const typeEmoji = p.type === 'entreprise' ? '🏢' : p.type === 'freelance' ? '💼' : '👤';\n  const interetEmoji = p.niveau_interet === 'chaud' ? '🔥' : p.niveau_interet === 'tiède' ? '🟡' : '❄️';\n  \n  let msg = scoreEmoji + ' *Prospect — Score : ' + p.score_pertinence + '/10*\\n';\n  msg += typeEmoji + ' Type : `' + p.type + '` | ' + interetEmoji + ' Intérêt : `' + p.niveau_interet + '`\\n\\n';\n  msg += '📛 *Nom :* ' + (p.nom || 'Inconnu') + '\\n';\n  if (p.email) msg += '📧 *Email :* ' + p.email + (p.email_valide ? ' ✅' : ' ⚠️') + '\\n';\n  if (p.telephone) msg += '📞 *Tél :* ' + p.telephone + '\\n';\n  if (p.linkedin_url) msg += '🔗 *LinkedIn :* ' + p.linkedin_url + '\\n';\n  if (p.site_web) msg += '🌐 *Site :* ' + p.site_web + '\\n';\n  if (p.localisation) msg += '📍 *Localisation :* ' + p.localisation + '\\n';\n  msg += '\\n📝 *Résumé :*\\n' + (p.resume_profil || 'Non disponible') + '\\n';\n  if (p.points_forts && p.points_forts.length > 0) {\n    msg += '\\n✅ *Points forts :* ' + p.points_forts.join(' · ') + '\\n';\n  }\n  msg += '\\n💬 _' + (p.justification_score || '') + '_';\n  return msg;\n}}",
                "additionalFields": {
                    "disable_notification": false,
                    "parse_mode": "Markdown"
                }
            },
