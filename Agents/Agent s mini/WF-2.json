            "id": "847f9494-107b-4c5f-a037-a28ad2e9c9f7",
            "name": "Split Boucle Prospects",
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 3,
            "position": [
                -32,
                9456
