            "id": "a2ce6159-f782-437c-9e13-ab72720e9ba6",
            "name": "Apify LinkedIn Scraper",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1008,
                208
            ]
        },
        {
            "parameters": {
                "jsCode": "const raw = $input.first().json;\nconst results = Array.isArray(raw) ? raw : (raw.data || [raw]);\n\nif (!results || results.length === 0) return [];\n\nreturn results\n  .filter(item =\u003e item \u0026\u0026 (item.name || item.fullName || item.headline))\n  .map(item =\u003e ({\n    json: {\n      source: \u0027linkedin\u0027,\n      nom: item.name || item.fullName || \u0027\u0027,\n      titre_poste: item.headline || item.title || \u0027\u0027,\n      linkedin_url: item.profileUrl || item.url || null,\n      localisation: item.location || null,\n      entreprise_actuelle: item.currentCompany || null,\n      email: item.email || null,\n      telephone: item.phone || null,\n      site_web: item.websiteUrl || null,\n      url: item.profileUrl || item.url || null\n    }\n  }));"
            },
            "id": "09ebe0af-4210-4c40-92cc-7af5e6fd5eb0",
            "name": "Extraire Resultats LinkedIn",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1264,
                208
            ]
        },
        {
            "parameters": {
                "jsCode": "const googleAggr = $(\u0027Agreger Resultats Google\u0027).first().json;\nconst googleData = googleAggr.resultats_google || [];\n\nconst linkedinItems = $input.all();\nconst linkedinData = linkedinItems.map(i =\u003e i.json);\n\nconst params = $(\u0027Extraire Parametres Recherche\u0027).first().json;\n\nconst allResults = [...googleData, ...linkedinData];\nconst unique = [];\nconst seen = new Set();\nfor (const r of allResults) {\n  const key = r.url || r.linkedin_url || r.nom || r.titre;\n  if (key \u0026\u0026 !seen.has(key)) {\n    seen.add(key);\n    unique.push(r);\n  }\n}\n\nreturn [{\n  json: {\n    session_id: params.session_id,\n    chat_id: params.chat_id,\n    type: params.type,\n    secteur: params.secteur,\n    localisation: params.localisation,\n    description_cible: params.description_cible,\n    criteres_scoring: params.criteres_scoring,\n    total_trouve: unique.length,\n    resultats: unique\n  }\n}];"
            },
            "id": "0ee2cc3e-ead6-4096-8a07-5d4e8120595d",
            "name": "Combiner Google et LinkedIn",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1504,
                208
            ]
        },
        {
            "parameters": {
                "jsCode": "const data = $input.first().json;\nconst resultats = data.resultats || [];\n\nconst exclusions = [\n  \u0027linkedin.com\u0027, \u0027facebook.com\u0027, \u0027twitter.com\u0027, \u0027instagram.com\u0027,\n  \u0027pagesjaunes.fr\u0027, \u0027societe.com\u0027, \u0027kompass.com\u0027, \u0027google.com\u0027,\n  \u0027youtube.com\u0027, \u0027wikipedia.org\u0027\n];\n\nconst sitesAScraper = resultats\n  .filter(r =\u003e {\n    const url = r.url || r.site_web;\n    if (!url || !url.startsWith(\u0027http\u0027)) return false;\n    return !exclusions.some(ex =\u003e url.includes(ex));\n  })\n  .map(r =\u003e ({ url: r.url || r.site_web, source_data: r }))\n  .slice(0, 10);\n\nreturn sitesAScraper.map(site =\u003e ({\n  json: {\n    url_a_scraper: site.url,\n    source_data: site.source_data,\n    contexte: {\n      session_id: data.session_id,\n      chat_id: data.chat_id,\n      type: data.type,\n      secteur: data.secteur,\n      localisation: data.localisation,\n      description_cible: data.description_cible,\n      criteres_scoring: data.criteres_scoring,\n      total_resultats: data.total_trouve,\n      tous_resultats: data.resultats\n    }\n  }\n}));"
            },
            "id": "1d71e045-cdd9-4edd-b749-53b3bf805967",
            "name": "Preparer Sites a Scraper",
