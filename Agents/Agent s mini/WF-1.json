        {
            "parameters": {
                "method": "POST",
                "url": "https://api.deepseek.com/chat/completions",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"model\": \"deepseek-chat\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu analyses une demande de prospection et tu renvoies STRICTEMENT un JSON valide avec: type, secteur, localisation, description_cible, nb_resultats, requetes_google (array), criteres_scoring.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $(\u0027When Called By WF-0\u0027).first().json.texte }}\"\n    }\n  ]\n}",
                "options": {}
            },
            "id": "9cbb08e2-c37b-4785-a28b-dba0cef0534f",
            "name": "DeepSeek Analyser Demande",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                -496,
                208
            ],
            "credentials": {
                "httpHeaderAuth": {
                    "id": "Fi7piKShxfsxAA0V",
                    "name": "Header Auth agent_s"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "const item = $input.first().json;\nconst content = item.choices[0].message.content;\n\nlet params;\ntry {\n  const clean = content.replace(/```json|```/g, \u0027\u0027).trim();\n  params = JSON.parse(clean);\n} catch(e) {\n  throw new Error(\u0027Erreur parsing JSON DeepSeek: \u0027 + content);\n}\n\n// RÃƒÆ’Ã‚Â©cupÃƒÆ’Ã‚Â©rer chat_id depuis WF-0\nconst triggerData = $(\u0027When Called By WF-0\u0027).first().json;\nparams.chat_id = String(triggerData.chat_id || \u0027\u0027);\nparams.message_original = triggerData.texte || \u0027\u0027;\nparams.session_id = \u0027acq_\u0027 + Date.now();\nparams.created_at = new Date().toISOString();\n\n// Validation des champs critiques\nif (!params.requetes_google || !Array.isArray(params.requetes_google) || params.requetes_google.length === 0) {\n  throw new Error(\u0027Champ requetes_google manquant ou vide dans la rÃƒÆ’Ã‚Â©ponse DeepSeek\u0027);\n}\nif (![\u0027entreprise\u0027, \u0027freelance\u0027, \u0027particulier\u0027].includes(params.type)) {\n  throw new Error(\u0027Type de profil invalide: \u0027 + params.type);\n}\n\nreturn [{ json: params }];"
            },
