                  {
                      "parameters":  {
                                         "jsCode":  "const now = new Date();\nconst items = $input.all();\nconst rappelsAEnvoyer = [];\n\nfor (const item of items) {\n  const a = item.json;\n  const dateAppel = new Date(a.date_appel);\n  const diffMs = dateAppel.getTime() - now.getTime();\n  const diffMin = diffMs / 60000;\n\n  if (diffMin \u003e= 175 \u0026\u0026 diffMin \u003c= 185 \u0026\u0026 !a.rappel_3h_envoye) {\n    rappelsAEnvoyer.push({ json: { ...a, type_rappel: \u00273h\u0027, emoji: \u0027ÃƒÂ¢Ã‚ÂÃ‚Â°\u0027, message_rappel: \u0027dans 3 heures\u0027 } });\n  } else if (diffMin \u003e= 55 \u0026\u0026 diffMin \u003c= 65 \u0026\u0026 !a.rappel_1h_envoye) {\n    rappelsAEnvoyer.push({ json: { ...a, type_rappel: \u00271h\u0027, emoji: \u0027ÃƒÂ°Ã…Â¸Ã¢â‚¬ÂÃ¢â‚¬Â\u0027, message_rappel: \u0027dans 1 heure\u0027 } });\n  } else if (diffMin \u003e= 25 \u0026\u0026 diffMin \u003c= 35 \u0026\u0026 !a.rappel_30min_envoye) {\n    rappelsAEnvoyer.push({ json: { ...a, type_rappel: \u002730min\u0027, emoji: \u0027ÃƒÂ°Ã…Â¸Ã…Â¡Ã‚Â¨\u0027, message_rappel: \u0027dans 30 minutes\u0027 } });\n  } else if (diffMin \u003e= -5 \u0026\u0026 diffMin \u003c= 5 \u0026\u0026 !a.rappel_heure_envoye) {\n    rappelsAEnvoyer.push({ json: { ...a, type_rappel: \u0027heure_h\u0027, emoji: \u0027ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã…Â¾\u0027, message_rappel: \"C\u0027EST L\u0027HEURE !\" } });\n  }\n}\n\nreturn rappelsAEnvoyer.length \u003e 0 ? rappelsAEnvoyer : [];"
