                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const response = $input.first().json || {};\nconst content = response?.choices?.[0]?.message?.content || \u0027\u0027;\nconst triggerData = $(\u0027When Called By WF-0\u0027).first().json || {};\n\nlet parsed;\ntry {\n  const clean = String(content).replace(/```json|```/g, \u0027\u0027).trim();\n  parsed = JSON.parse(clean);\n} catch (e) {\n  parsed = {};\n}\n\nif (!parsed.message_valide || parsed.action !== \u0027planifier_appel\u0027 || !parsed.date_appel_iso) {\n  return [{ json: { action: \u0027non_reconnu\u0027, chat_id: String(triggerData.chat_id || \u0027\u0027) } }];\n}\n\nconst dateAppel = new Date(parsed.date_appel_iso);\nif (Number.isNaN(dateAppel.getTime()) || dateAppel \u003c new Date()) {\n  return [{ json: { action: \u0027non_reconnu\u0027, chat_id: String(triggerData.chat_id || \u0027\u0027) } }];\n}\n\nconst duree = Math.min(120, Math.max(15, Number.parseInt(parsed.duree_minutes, 10) || 30));\nconst dateFin = new Date(dateAppel.getTime() + duree * 60000);\n\nreturn [{\n  json: {\n    action: \u0027planifier_appel\u0027,\n    chat_id: String(triggerData.chat_id || \u0027\u0027),\n    prospect_id: parsed.prospect_id || null,\n    prospect_nom: (typeof parsed.prospect_nom === \u0027string\u0027 \u0026\u0026 parsed.prospect_nom.trim()) ? parsed.prospect_nom.trim() : \u0027Prospect\u0027,\n    date_appel_iso: dateAppel.toISOString(),\n    date_fin_iso: dateFin.toISOString(),\n    date_appel_affichage: dateAppel.toLocaleDateString(\u0027fr-FR\u0027, { weekday: \u0027long\u0027, day: \u0027numeric\u0027, month: \u0027long\u0027 }),\n    heure_affichage: dateAppel.toLocaleTimeString(\u0027fr-FR\u0027, { hour: \u00272-digit\u0027, minute: \u00272-digit\u0027 }),\n    duree_minutes: duree,\n    notes_appel: typeof parsed.notes_appel === \u0027string\u0027 ? parsed.notes_appel.trim() : null\n  }\n}];"
                                     },
